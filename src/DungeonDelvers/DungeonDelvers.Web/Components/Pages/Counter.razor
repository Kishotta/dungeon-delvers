@page "/counter"

<PageTitle>Counter</PageTitle>

<MudText Typo="Typo.h1">Counter</MudText>

<MudText Typo="Typo.body1" role="status">Current count: @_currentCount</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" @onclick="IncrementCount">Click me</MudButton>

@code {
    private int _currentCount = 0;

    private void IncrementCount()
    {
        _currentCount++;
    }
}
